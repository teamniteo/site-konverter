---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero.astro";
import Testimonial from "@/components/Testimonial.astro";
import Steps from "@/components/Steps.astro";
import Benefits from "@/components/Benefits.astro";
import Pricing from "@/components/Pricing.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import type { WebSite, Organization } from "schema-dts";

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Konverter.si",
  url: Astro.url.origin,
  description: "Pretvorite PDF račune v XML za Minimax. 99%+ točnost podatkov.",
} satisfies WebSite;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Niteo SI d.o.o.",
  url: Astro.url.origin,
  email: "podpora@konverter.si",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Trg komandanta Staneta 8",
    addressLocality: "Ljubljana",
    postalCode: "1000",
    addressCountry: "SI",
  },
} satisfies Organization;
---

<Layout title="Od PDF-ja v Minimax v manj kot minuti" schema={[websiteSchema, orgSchema]}>
  <Hero />
  <Testimonial />
  <Steps />
  <Benefits />
  <Pricing />
  <CtaBanner />
</Layout>
