---
import Layout from "@/layouts/Layout.astro";
import type { WebPage } from "schema-dts";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Stran ni bila najdena",
} satisfies WebPage;
---

<Layout title="Stran ni bila najdena" noindex schema={schema}>
  <div class="flex flex-col items-center justify-center py-32 px-4 text-center">
    <h1 class="text-8xl font-bold text-brand-navy">404</h1>
    <p class="mt-4 text-lg text-muted-foreground">Stran, ki jo iščete, ne obstaja.</p>
    <a
      href="/"
      class="mt-8 inline-flex items-center justify-center rounded-lg bg-brand-navy px-6 py-2.5 text-sm font-semibold text-white hover:opacity-90 transition-opacity"
    >
      Nazaj na domačo stran
    </a>
  </div>
</Layout>
