---
import logoSvg from "@/assets/logo.svg";
---

<footer class="bg-brand-navy text-white/90">
  <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-8">
      <!-- Company info -->
      <div class="space-y-4">
        <img src={logoSvg.src} alt="Konverter.si" class="h-7 w-auto brightness-0 invert" />
        <div class="text-base text-white/60 leading-relaxed">
          <p class="font-medium text-white/80">Niteo SI d.o.o.</p>
          <p>Trg komandanta Staneta 8</p>
          <p>1000 Ljubljana, Slovenija</p>
        </div>
        <a href="mailto:podpora@konverter.si" class="text-base text-brand-cyan hover:text-white transition-colors">
          podpora@konverter.si
        </a>
      </div>

      <!-- Legal links -->
      <div class="space-y-4 md:text-right">
        <h3 class="text-base font-semibold uppercase tracking-wider text-white/50">Pravne informacije</h3>
        <nav class="flex flex-col gap-2.5" aria-label="Pravne informacije">
          <a href="/podjetje/" class="text-base text-white/60 hover:text-white transition-colors">O podjetju</a>
          <a href="/pogoji/" class="text-base text-white/60 hover:text-white transition-colors">Pogoji uporabe</a>
          <a href="/zasebnost/" class="text-base text-white/60 hover:text-white transition-colors">Politika zasebnosti</a>
        </nav>
      </div>

    </div>

    <div class="mt-12 pt-6 border-t border-white/10 text-center">
      <p class="text-base text-white/40">
        &copy; {new Date().getFullYear()} Konverter.si &middot; Vse pravice pridržane
      </p>
    </div>
  </div>
</footer>
