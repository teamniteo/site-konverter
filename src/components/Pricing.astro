---
import { Badge } from "@/components/ui/badge";
---

<section id="cenik" class="py-16 md:py-20 bg-muted/50">
  <div class="mx-auto max-w-4xl px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy">Cenik</h2>
      <p class="mt-3 text-lg text-muted-foreground">Enostavno in pregledno. Brez skritih stroškov.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
      <!-- Basic Plan -->
      <div class="rounded-2xl border border-border bg-card p-8 shadow-soft">
        <div class="mb-6">
          <h3 class="text-xl font-semibold text-foreground">Konverter 150</h3>
          <p class="text-base text-muted-foreground mt-1">Za manjše pisarne</p>
        </div>

        <div class="mb-6">
          <span class="text-5xl font-bold text-brand-navy">15 €</span>
          <span class="text-lg text-muted-foreground">/mesec</span>
        </div>

        <ul class="space-y-3 mb-8 text-base">
          <li class="flex items-start gap-2.5">
            <svg class="w-5 h-5 text-brand-cyan flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <span class="text-foreground">Do <strong>150 računov</strong> mesečno</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-5 h-5 text-brand-cyan flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <span class="text-foreground">5 € za dodatnih 100 računov</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-5 h-5 text-brand-cyan flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <span class="text-foreground">Plačilo s kartico in takojšen dostop</span>
          </li>
        </ul>

        <a
          href="https://app.konverter.si/register"
          class="block w-full text-center rounded-lg border-2 border-brand-navy px-4 py-3 text-base font-semibold text-brand-navy hover:bg-brand-navy hover:text-white transition-colors"
        >
          Preizkusi 10 brezplačnih pretvorb
        </a>
      </div>

      <!-- Pro Plan -->
      <div class="relative rounded-2xl border-2 border-brand-navy bg-card p-8 shadow-medium">
        <div class="absolute -top-3 right-6">
          <Badge className="bg-brand-red text-white border-0 px-3 py-1 text-sm font-semibold">
            Najbolj priljubljeno
          </Badge>
        </div>

        <div class="mb-6">
          <h3 class="text-xl font-semibold text-foreground">Konverter 1000</h3>
          <p class="text-base text-muted-foreground mt-1">Za računovodske servise</p>
        </div>

        <div class="mb-6">
          <span class="text-5xl font-bold text-brand-navy">50 €</span>
          <span class="text-lg text-muted-foreground">/mesec</span>
        </div>

        <ul class="space-y-3 mb-8 text-base">
          <li class="flex items-start gap-2.5">
            <svg class="w-5 h-5 text-brand-cyan flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <span class="text-foreground">Do <strong>1.000 računov</strong> mesečno</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-5 h-5 text-brand-cyan flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <span class="text-foreground">5 € za dodatnih 100 računov</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-5 h-5 text-brand-cyan flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <span class="text-foreground">Plačilo s kartico in takojšen dostop</span>
          </li>
        </ul>

        <a
          href="https://app.konverter.si/register"
          class="block w-full text-center rounded-lg bg-brand-red px-4 py-3 text-base font-semibold text-white hover:opacity-90 transition-opacity"
        >
          Preizkusi 10 brezplačnih pretvorb
        </a>
      </div>
    </div>

    <p class="text-center text-base text-muted-foreground mt-6">
      Cena ne vključuje DDV.
    </p>
  </div>
</section>
