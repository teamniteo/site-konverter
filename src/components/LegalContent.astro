---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="mx-auto max-w-3xl px-4 py-16 md:py-20">
  <h1 class="text-3xl md:text-4xl font-bold text-brand-navy mb-10">{title}</h1>

  <div class="prose-legal space-y-6 text-lg text-foreground leading-relaxed [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:text-brand-navy [&_h2]:mt-10 [&_h2]:mb-4 [&_p]:text-muted-foreground [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1.5 [&_ul]:text-muted-foreground [&_li]:text-muted-foreground [&_strong]:text-foreground [&_a]:text-brand-cyan [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-brand-navy">
    <slot />
  </div>

</div>
